{
  "manifest_version": 3,
  "name": "Nepali News Ad Blocker",
  "version": "1.4",
  "description": "Hides ads on major Nepali news sites.",
  "content_scripts": [
    {
      "matches": [
        "*://annapurnapost.com/*",
        "*://*.annapurnapost.com/*",
        "*://baahrakhari.com/*",
        "*://*.baahrakhari.com/*",
        "*://bbc.com/nepali/*",
        "*://www.bbc.com/nepali/*",
        "*://*.bbc.com/nepali/*",
        "*://deshsanchar.com/*",
        "*://*.deshsanchar.com/*",
        "*://ekantipur.com/*",
        "*://*.ekantipur.com/*",
        "*://gorkhapatra.org.np/*",
        "*://*.gorkhapatra.org.np/*",
        "*://gorkhapatraonline.com/*",
        "*://*.gorkhapatraonline.com/*",
        "*://himalayatv.com/*",
        "*://*.himalayatv.com/*",
        "*://kantipurtv.com/*",
        "*://*.kantipurtv.com/*",
        "*://kathmandupost.com/*",
        "*://*.kathmandupost.com/*",
        "*://nagariknetwork.com/*",
        "*://*.nagariknetwork.com/*",
        "*://nepalpress.com/*",
        "*://*.nepalpress.com/*",
        "*://news24nepal.com/*",
        "*://*.news24nepal.com/*",
        "*://nepaltvonline.com/*",
        "*://*.nepaltvonline.com/*",
        "*://ntv.org.np/*",
        "*://*.ntv.org.np/*",
        "*://onlinekhabar.com/*",
        "*://*.onlinekhabar.com/*",
        "*://ratopati.com/*",
        "*://*.ratopati.com/*",
        "*://risingnepaldaily.com/*",
        "*://*.risingnepaldaily.com/*",
        "*://sagarmatha.tv/*",
        "*://*.sagarmatha.tv/*",
        "*://setopati.com/*",
        "*://*.setopati.com/*",
        "*://thehimalayantimes.com/*",
        "*://*.thehimalayantimes.com/*",
        "*://therisingnepal.org.np/*",
        "*://*.therisingnepal.org.np/*",
        "*://ujyaaloonline.com/*",
        "*://*.ujyaaloonline.com/*",
        "*://ukeraa.com/*",
        "*://*.ukeraa.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
